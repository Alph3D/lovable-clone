{
	"name": "lovable-clone",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "mprocs \"pnpm run dev:next\" \"pnpm run dev:webhook\" \"pnpm run dev:inngest\" \"pnpm run db:studio\"",
		"dev:next": "next dev --turbopack",
		"dev:webhook": "ngrok http --url=wired-legible-monster.ngrok-free.app 3000",
		"dev:inngest": "inngest-cli dev",
		"build": "next build --turbopack",
		"start": "next start",
		"lint": "eslint",
		"lint:fix": "eslint --fix",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"db:migrate": "dotenv -e .env.local -- prisma migrate dev",
		"db:reset": "dotenv -e .env.local -- prisma migrate reset",
		"db:generate": "dotenv -e .env.local -- prisma generate",
		"db:studio": "dotenv -e .env.local -- prisma studio",
		"postinstall": "pnpm run db:generate"
	},
	"dependencies": {
		"@clerk/nextjs": "^6.35.1",
		"@clerk/themes": "^2.4.36",
		"@e2b/code-interpreter": "^2.1.0",
		"@hookform/resolvers": "^5.2.2",
		"@inngest/agent-kit": "^0.13.1",
		"@prisma/client": "^6.17.1",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.3",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@t3-oss/env-nextjs": "^0.13.8",
		"@tanstack/react-query": "^5.90.5",
		"@trpc/client": "^11.6.0",
		"@trpc/server": "^11.6.0",
		"@trpc/tanstack-react-query": "^11.6.0",
		"class-variance-authority": "^0.7.1",
		"client-only": "^0.0.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"inngest": "^3.44.3",
		"lucide-react": "^0.545.0",
		"next": "15.5.7",
		"next-themes": "^0.4.6",
		"prismjs": "^1.30.0",
		"random-word-slugs": "^0.1.7",
		"rate-limiter-flexible": "^9.0.0",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-error-boundary": "^6.0.0",
		"react-hook-form": "^7.66.0",
		"react-hot-toast": "^2.6.0",
		"react-resizable-panels": "^3.0.6",
		"react-textarea-autosize": "^8.5.9",
		"server-only": "^0.0.1",
		"superjson": "^2.2.2",
		"tailwind-merge": "^3.3.1",
		"zod": "^4.1.12",
		"zustand": "^5.0.10"
	},
	"devDependencies": {
		"@babel/eslint-parser": "^7.28.4",
		"@eslint/eslintrc": "^3",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.0",
		"@next/eslint-plugin-next": "^15.5.4",
		"@tailwindcss/postcss": "^4",
		"@trivago/prettier-plugin-sort-imports": "^5.2.2",
		"@types/node": "^20",
		"@types/prismjs": "^1.26.5",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"dotenv-cli": "^10.0.0",
		"eslint": "^9",
		"eslint-config-next": "15.5.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"eslint-plugin-react-hooks": "^7.0.0",
		"eslint-plugin-tailwindcss": "4.0.0-beta.0",
		"prettier": "^3.6.2",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"prisma": "^6.17.1",
		"sort-classes": "npm:prettier-plugin-tailwindcss",
		"tailwind-scrollbar": "^4.0.2",
		"tailwindcss": "^4",
		"tidy-imports": "npm:@trivago/prettier-plugin-sort-imports",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5"
	}
}
